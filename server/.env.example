# Server port
PORT=3001

# Supabase project URL (from Supabase Dashboard → Settings → API)
# Used to build verification links
SUPABASE_URL=https://your-project.supabase.co

# Nodemailer - Gmail example (use App Password, not normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Shine & Span <your-email@gmail.com>

# Optional: Webhook secret to verify requests from Supabase (if using signed webhooks)
# AUTH_HOOK_SECRET=
