# Supabase - Get these from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Site URL for auth redirects (e.g. password reset). Use your Netlify URL in production.
# Leave empty to use current origin (window.location.origin)
VITE_APP_URL=https://your-app.netlify.app
